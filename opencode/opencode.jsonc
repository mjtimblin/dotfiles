{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@slkiser/opencode-quota@3.3.0",
    "@tarquinen/opencode-dcp@3.1.3",
    "@plannotator/opencode@0.17.3",
    "@cortexkit/aft-opencode@0.16.1",
  ],
  "experimental": {
    "quotaToast": {
      "enabledProviders": ["openai", "zai"],
      "minIntervalMs": 300000, // 5 minutes between fetches
      "toastDurationMs": 10000, // Toast shows for 10 seconds
    },
  },
}

