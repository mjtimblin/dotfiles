{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@slkiser/opencode-quota@3.4.0",
    "@tarquinen/opencode-dcp@3.1.9",
    "@plannotator/opencode@0.19.3",
    "@cortexkit/aft-opencode@0.17.3",
    ["opencode-auto-resume@1.0.10", {
      "chunkTimeoutMs": 45000,
      "maxRetries": 3,
      "subagentWaitMs": 15000,
      "loopWindowMs": 600000,
    }],
  ],
  "experimental": {
    "quotaToast": {
      "enabledProviders": ["openai", "zai"],
      "minIntervalMs": 300000, // 5 minutes between fetches
      "toastDurationMs": 10000, // Toast shows for 10 seconds
    },
  },
}

